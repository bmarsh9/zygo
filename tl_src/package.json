{
  "name": "flowchart-tailwind",
  "private": true,
  "scripts": {
    "build": "npx tailwindcss -c tailwind.config.js -i main.css -o ../app/static/css/output.css --minify",
    "watch": "npx tailwindcss -c tailwind.config.js -i main.css -o ../app/static/css/output.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4",
